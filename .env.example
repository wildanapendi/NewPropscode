# ===========================================
# Environment Variables Template
# ===========================================
# Copy this file to .env and fill in actual values
# NEVER commit the .env file to version control!
# ===========================================

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_NAME=propscode_db_new

# JWT (Generate a new secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Server
PORT=5000
PORT_API_URL=http://localhost:5000/api

# Telegram Bot (Get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_BYPASS_TOKEN=your_bypass_token_here
